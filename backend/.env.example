# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/astrocycle
PGHOST=localhost
PGPORT=5432
PGDATABASE=astrocycle
PGUSER=postgres
PGPASSWORD=password

# Security
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# SwissEphemeris
SWISSEPH_PATH=./ephemeris

# AI Provider Order - Add new providers here
AI_PROVIDER_ORDER=kie,openai,gemini,deepseek,xai,deepseek_v3,qwen_coder,mistral,claude_sonnet,gpt5,kimi,kimi_free,qwen_coder_free,gemma,gpt5_o3

# KIE AI Configuration (Claude)
KIE_API_KEY=your-kie-api-key-here
KIE_MODEL=claude-opus-4-6

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek V3 Configuration
DEEPSEEK_V3_API_KEY=your-deepseek-v3-api-key-here
DEEPSEEK_V3_MODEL=deepseek-v3

# xAI (Grok) Configuration
XAI_API_KEY=your-xai-api-key-here
XAI_MODEL=grok-4.3

# Qwen Coder Configuration
QWEN_CODER_API_KEY=your-qwen-coder-api-key-here
QWEN_CODER_MODEL=qwen-coder

# Mistral Configuration
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-medium-3.5

# Claude Sonnet Configuration
CLAUDE_SONNET_API_KEY=your-claude-sonnet-api-key-here
CLAUDE_SONNET_MODEL=claude-sonnet-4.6

# GPT-5 Configuration
GPT5_API_KEY=your-gpt5-api-key-here
GPT5_MODEL=gpt-5

# Kimi Configuration
KIMI_API_KEY=your-kimi-api-key-here
KIMI_MODEL=kimi-k2.6

# Kimi Free Configuration
KIMI_FREE_API_KEY=your-kimi-free-api-key-here
KIMI_FREE_MODEL=kimi-k2.6-free

# Qwen Coder Free Configuration
QWEN_CODER_FREE_API_KEY=your-qwen-coder-free-api-key-here
QWEN_CODER_FREE_MODEL=qwen-coder-free

# Gemma Configuration
GEMMA_API_KEY=your-gemma-api-key-here
GEMMA_MODEL=gemma-4-31b-free

# GPT-5 o3 Configuration
GPT5_O3_API_KEY=your-gpt5-o3-api-key-here
GPT5_O3_MODEL=gpt-5-o3

# Multiple API keys can be comma-separated for automatic rotation
# Example: KIE_API_KEY=key1,key2,key3